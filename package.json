{
  "name": "@anilkumarthakur/d8",
  "private": false,
  "version": "0.0.0",
  "description": "A modern, zero-dependency TypeScript date/time library — formatting, parsing, timezones, business days, cron, and natural language.",
  "type": "module",
  "main": "dist/index.umd.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/anilkumarthakur60/snaptime.git"
  },
  "homepage": "https://anilkumarthakur60.github.io/snaptime/",
  "bugs": {
    "url": "https://github.com/anilkumarthakur60/snaptime/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "date",
    "time",
    "datetime",
    "typescript",
    "timezone",
    "cron",
    "duration",
    "business-days",
    "date-formatting",
    "date-parsing",
    "natural-language",
    "zero-dependency"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js"
    }
  },
  "author": "Anil Kumar Thakur",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ignore-pattern node_modules/ --ignore-pattern dist/ --ignore-pattern package-lock.json",
    "format": "prettier --write src/ test/",
    "format:check": "prettier --check src/",
    "test": "jest --watch",
    "jest": "jest",
    "test:coverage": "jest --coverage --coverageReporters=text --coverageReporters=lcov",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "eslint": "^9.26.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "prettier": "3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4"
  }
}